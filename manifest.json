{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "__MSG_extName__",
    "default_popup": "popup.html"
  },
  "permissions": ["scripting"],
  "host_permissions": [
    "*://iq.com/*",
    "*://*.iq.com/*",
    "*://iqiyi.com/*",
    "*://*.iqiyi.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://iq.com/*",
        "*://*.iq.com/*",
        "*://iqiyi.com/*",
        "*://*.iqiyi.com/*"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
